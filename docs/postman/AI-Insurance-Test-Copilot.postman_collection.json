    {
      "name": "Test Cases",
      "item": [
        {
          "name": "POST /api/v1/test-cases",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "let data = {};",
                  "try {",
                  "  data = pm.response.json();",
                  "} catch (e) {",
                  "  data = {};",
                  "}",
                  "",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set('testCaseId', data.id);",
                  "}",
                  "",
                  "pm.test('Response has id', function () {",
                  "  pm.expect(data.id).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"name\": \"Insurance Premium Validation\",\n  \"appUrl\": \"https://example-insurance-app.com\",\n  \"insuranceInput\": {\n    \"age\": 35,\n    \"sumInsured\": 1000000,\n    \"policyType\": \"Term\",\n    \"rider\": \"Critical Illness\",\n    \"premiumExpected\": 15420.5\n  },\n  \"steps\": [\n    {\n      \"order\": 1,\n      \"action\": \"goto\",\n      \"value\": \"https://example-insurance-app.com/quote\"\n    },\n    {\n      \"order\": 2,\n      \"action\": \"fill\",\n      \"selector\": \"#age\",\n      \"value\": \"35\"\n    },\n    {\n      \"order\": 3,\n      \"action\": \"click\",\n      \"selector\": \"#calculatePremium\"\n    },\n    {\n      \"order\": 4,\n      \"action\": \"assert\",\n      \"selector\": \"#premiumValue\",\n      \"expected\": {\n        \"contains\": \"15420\"\n      }\n    }\n  ],\n  \"createdBy\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/test-cases/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "test-cases",
                ""
              ]
            },
            "description": "Create a test case. Saves returned id to collection variable testCaseId."
          },
          "response": []
        },
